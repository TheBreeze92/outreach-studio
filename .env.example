# Anthropic — required for email generation and web research
ANTHROPIC_API_KEY=

# Supabase — required for email signup storage
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Upstash Redis — optional, enables rate limiting (5 generations/hour per IP)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Slack — optional, enables error alerts and signup notifications
SLACK_ERROR_WEBHOOK_URL=
SLACK_SIGNUP_WEBHOOK_URL=
