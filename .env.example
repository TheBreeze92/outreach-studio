# Anthropic — primary AI provider for email generation and web research
ANTHROPIC_API_KEY=

# Google Gemini — fallback AI provider (activates automatically if Anthropic is unavailable)
GOOGLE_AI_API_KEY=

# Supabase — required for email signup storage
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase Auth — anon key is required for magic-link sign-in (client + server session)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Public site origin — used for magic-link + Stripe redirect URLs (e.g. https://yourapp.com)
NEXT_PUBLIC_SITE_URL=

# Stripe — required for the paid credit pack
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# Upstash Redis — optional, enables rate limiting (5 generations/hour per IP)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Slack — optional, enables error alerts and signup notifications
SLACK_ERROR_WEBHOOK_URL=
SLACK_SIGNUP_WEBHOOK_URL=
